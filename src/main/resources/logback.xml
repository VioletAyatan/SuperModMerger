<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="false"
>
    <!-- 定义变量 -->
    <property name="LOG_DIR" value="logs"/>
    <property name="DEBUG_LOG_FILE" value="${LOG_DIR}/app.log"/>
    <property name="CONSOLE_LOG_PATTERN" value="%msg%n"/>
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- 日志文件最大保留数量 -->
    <property name="MAX_FILES" value="20"/>
    <property name="MAX_FILE_SIZE" value="10MB"/>

    <!-- 控制台输出-->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
    </appender>

    <!-- 文件输出 -->
    <appender name="DEBUG_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${DEBUG_LOG_FILE}</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <!-- 滚动策略：基于固定数量的滚动，最多保留100个日志文件 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.FixedWindowRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archive/app.%i.log.gz</fileNamePattern>
            <minIndex>1</minIndex>
            <maxIndex>${MAX_FILES}</maxIndex>
        </rollingPolicy>
        <triggeringPolicy class="ch.qos.logback.core.rolling.SizeBasedTriggeringPolicy">
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
        </triggeringPolicy>
    </appender>

    <!-- 日志异步追加器 -->
    <appender name="ASYNC_DEBUG_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <!-- 队列深度 -->
        <queueSize>512</queueSize>
        <!-- 丢弃日志阈值 -->
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="DEBUG_FILE"/>
    </appender>

    <root level="DEBUG">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="ASYNC_DEBUG_FILE"/>
    </root>

    <logger name="ankol.mod.merger" level="DEBUG"/>
    <logger name="cn.hutool" level="WARN"/>
</configuration>

